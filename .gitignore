# macOS特有のファイル
.DS_Store

# Node.jsの依存モジュール（インストール時に自動生成されるため不要）
node_modules/

# ビルド後の出力ファイル（Firebase Hosting 用の `dist/` も含む）
/dist

# Firebase関連の一時ファイルやデバッグログ
/.firebase
/firebase-debug.log
/firebase-error.log

# Firebaseの設定ファイル（機密情報を含むためコミットしない）
#sc/firebase/index.js

# ローカル環境用の設定ファイル（環境変数を管理）
.env
.env.local
.env.development
.env.production
.env.*.local

# ログファイル
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# VS Codeの設定ファイル（個人の環境依存のためコミット不要）
.vscode/
*.code-workspace

# JetBrains系（WebStorm, IntelliJ）IDEの設定ファイル
.idea/

# Windows特有の設定ファイル
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Gitが管理する対象外にするもの（Firebaseエミュレーターの状態）
/firebase_export/